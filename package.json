{
  "name": "commandertrack",
  "version": "1.0.0",
  "description": "Magic the Gathering Commander Life & Timer Tracker PWA",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node -e \"const fs=require('fs');['node_modules/.vite','.svelte-kit'].forEach(d=>{fs.rmSync(d,{recursive:true,force:true})})\"",
    "dev": "npm run clean && vite dev",
    "dev:debug": "npm run clean && node scripts/switch-env.js debug && vite dev",
    "dev:firebase": "npm run clean && node scripts/switch-env.js firebase && vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "deploy": "npm run build && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:all": "npm run build && firebase deploy"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "sharp": "^0.34.5",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "firebase": "^11.0.0"
  }
}
