{
  "name": "commandertrack",
  "version": "1.0.0",
  "description": "Magic the Gathering Life Tracker with Timer",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:debug": "node -e \"require('fs').copyFileSync('.env.debug', '.env')\" && vite dev",
    "dev:firebase": "node -e \"require('fs').copyFileSync('.env.firebase', '.env')\" && vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "deploy": "npm run build && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:all": "npm run build && firebase deploy"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "firebase": "^11.0.0"
  }
}
