rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isZoneCreator(zoneId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/zones/$(zoneId)).data.creatorId == request.auth.uid;
    }

    // Account profiles — users can only write their own
    match /profiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Commander Zones — any authenticated user can read/create; write restricted
    match /zones/{zoneId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Active game state — users can only access their own
    match /activeGames/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Legacy players collection (kept for migration)
    match /players/{playerId} {
      allow read, write: if request.auth != null;
    }

    // Decks — any authenticated user can read; write allowed
    match /decks/{deckId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Game records — scoped by zone, any authenticated user
    match /games/{gameId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isZoneCreator(resource.data.zoneId);
    }

    // Game logs
    match /gameLogs/{logId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isSignedIn() && (
        !('zoneId' in resource.data) || resource.data.zoneId == null || isZoneCreator(resource.data.zoneId)
      );
    }

    // Analytics V2 telemetry stream
    match /analyticsEventsV2/{eventId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isZoneCreator(resource.data.zoneId);
    }
  }
}

